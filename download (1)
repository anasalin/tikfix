<div class="toast" id="toast"></div>

<script>
  let userLat = null, userLng = null;

  function go(id) { document.getElementById(id).scrollIntoView({ behavior:'smooth' }); }

  function showToast(msg, isError) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast' + (isError ? ' error' : '');
    t.style.display = 'block';
    setTimeout(() => t.style.display = 'none', 3500);
  }

  function getLocation() {
    const btn = document.getElementById('gpsBtn');
    btn.innerHTML = '<span>⏳</span> جاري تحديد موقعك...';
    btn.onclick = null;
    if (!navigator.geolocation) { showToast('المتصفح لا يدعم GPS', true); resetBtn(); return; }
    navigator.geolocation.getCurrentPosition(
      function(pos) {
        userLat = pos.coords.latitude.toFixed(6);
        userLng = pos.coords.longitude.toFixed(6);
        btn.classList.add('success');
        btn.innerHTML = '<span>✅</span> تم تحديد موقعك!';
        document.getElementById('coordsText').textContent = userLat + ' , ' + userLng;
        document.getElementById('mapFrame').src = 'https://maps.google.com/maps?q=' + userLat + ',' + userLng + '&z=16&output=embed';
        document.getElementById('gpsResult').style.display = 'block';
      },
      function(err) {
        showToast(err.code === 1 ? 'فعّل إذن الموقع من إعدادات المتصفح' : 'تعذر تحديد الموقع، أدخل عنوانك يدوياً', true);
        resetBtn();
      },
      { enableHighAccuracy: true, timeout: 10000 }
    );
  }

  function resetBtn() {
    const btn = document.getElementById('gpsBtn');
    btn.classList.remove('success');
    btn.innerHTML = '<span>🗺️</span> شارك موقعك الحالي';
    btn.onclick = getLocation;
  }

  function showManual() { document.getElementById('manualAddr').style.display = 'block'; }

  async function submitForm() {
    const name    = document.getElementById('name').value.trim();
    const phone   = document.getElementById('phone').value.trim();
    const device  = document.getElementById('device').value;
    const time    = document.getElementById('time').value;
    const problem = document.getElementById('problem').value.trim();
    const manual  = document.getElementById('manualInput').value.trim();

    if (!name || !phone || !device) { showToast('⚠️ من فضلك اكمل البيانات الأساسية', true); return; }
    if (!userLat && !manual) { showToast('⚠️ شارك موقعك أو أدخل عنوانك يدوياً', true); return; }

    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerHTML = '<span>⏳</span> جاري الإرسال...';

    try {
      const res = await fetch('/api/orders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, phone, device, time, problem, lat: userLat, lng: userLng, address: manual })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'خطأ في الإرسال');

      document.getElementById('successName').textContent = name;
      document.getElementById('formView').style.display = 'none';
      document.getElementById('successView').style.display = 'block';
    } catch(e) {
      showToast('❌ ' + e.message, true);
      btn.disabled = false;
      btn.innerHTML = '<span>🚀</span> أرسل الطلب';
    }
  }

  function openWA() {
    const name    = document.getElementById('name').value.trim();
    const phone   = document.getElementById('phone').value.trim();
    const device  = document.getElementById('device').value;
    const time    = document.getElementById('time').value;
    const problem = document.getElementById('problem').value.trim();
    const manual  = document.getElementById('manualInput').value.trim();
    const loc     = userLat ? 'https://maps.google.com/?q=' + userLat + ',' + userLng : (manual || 'لم يُحدد');
    const msg = `مرحبا، أريد حجز صيانة 🔧\n\nالاسم: ${name}\nالجوال: ${phone}\nالجهاز: ${device}\nالوقت: ${time||'لم يُحدد'}\nالمشكلة: ${problem||'لم يُذكر'}\nالموقع: ${loc}`;
    window.open('https://wa.me/970599000000?text=' + encodeURIComponent(msg), '_blank');
  }
</script>
